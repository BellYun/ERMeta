{
  "name": "ermeta-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ERMeta desktop client for Windows",
  "author": "ERMeta Team",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main/main.js && cross-env ERMETA_RENDERER_URL=http://localhost:5173 electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "installer:ncrc": "node ./scripts/run-installer-ncrc.mjs",
    "dist:win:test": "npm run dist:win && npm run installer:ncrc"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^36.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.ermeta.desktop",
    "productName": "ERMeta",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "protocols": [
      {
        "name": "ERMeta Steam Auth",
        "schemes": [
          "ermeta"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "runAfterFinish": false
    }
  }
}
